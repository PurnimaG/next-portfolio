    {
      "parameters": {
        "jsCode": "// Input rows from Postgres\nconst rows = items.map(item => item.json);\n\n// Get all unique dates\nconst allDates = [...new Set(\n  rows.map(r => {\n    return new Date(r.Date).toISOString().split('T')[0];\n  })\n)].sort();\n\nconst grouped = {};\n\n// Group by Client + Keyword\nfor (const row of rows) {\n\n  const client = row.Client;\n  const domain = row.Domain;\n  const keyword = row.Keyword;\n\n  const date = new Date(row.Date)\n    .toISOString()\n    .split('T')[0];\n\n  const rank = row.Rank;\n\n  const key = client + '|' + keyword;\n\n  if (!grouped[key]) {\n\n    grouped[key] = {\n      Client: client,\n      Domain: domain,\n      Keyword: keyword\n    };\n\n    // initialize all date columns blank\n    allDates.forEach(d => {\n      grouped[key][d] = \"\";\n    });\n\n  }\n\n  // put rank under matching date column\n  grouped[key][date] = rank;\n}\n\n\n// Convert back to n8n format\nreturn Object.values(grouped).map(row => ({\n  json: row\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
