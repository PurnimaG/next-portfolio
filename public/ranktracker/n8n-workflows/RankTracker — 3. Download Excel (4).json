      "id": "5815807b-c3af-4143-ae85-fd3db7f10b5e",
      "name": "DataForSEO — fetch SERP",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1232,
        352
      ],
      "notes": "Replace with your preferred SERP API. ValueSERP alternative shown in comments below.\n\nValueSERP alternative URL:\nhttps://api.valueserp.com/search?api_key=YOUR_KEY&q={{ $json.keyword }}&gl={{ $json.country }}&num=100\n\nFor ValueSERP, change HTTP method to GET and remove the body."
    },
    {
      "parameters": {
        "jsCode": "// Process ALL input items, not just the first one\nconst results = [];\n\nfor (let idx = 0; idx < $input.all().length; idx++) {\n  const serpResponse = $input.all()[idx].json;\n  \n  // Get the paired keyword data from the split node using the same index\n  const originalData = $('Split into one item per keyword').all()[idx].json;\n\n  const keyword = originalData.keyword;\n  const domain = originalData.domain || '';\n  const client_id = originalData.client_id;\n  const client_name = originalData.client_name;\n  const country = originalData.country;\n  const engine = originalData.engine;\n\n  const organicResults = serpResponse.organic_results || [];\n\n  let rank = null;\n  let rankingUrl = '';\n  let rankingTitle = '';\n\n  const cleanDomain = domain\n    .replace(/^https?:\\/\\//, '')\n    .replace(/^www\\./, '')\n    .toLowerCase();\n\n  for (let i = 0; i < organicResults.length; i++) {\n    const result = organicResults[i];\n    const resultLink = (result.link || result.displayed_link || '')\n      .replace(/^https?:\\/\\//, '')\n      .replace(/^www\\./, '')\n      .toLowerCase();\n\n    if (resultLink.startsWith(cleanDomain)) {\n      rank = result.position || (i + 1);\n      rankingUrl = result.link || '';\n      rankingTitle = result.title || '';\n      break;\n    }\n  }\n\n  let tier = 'Not Ranked';\n  if (rank !== null) {\n    if (rank <= 3) tier = 'Top 3';\n    else if (rank <= 10) tier = 'Top 10';\n    else if (rank <= 20) tier = 'Top 20';\n    else if (rank <= 50) tier = 'Top 50';\n    else tier = 'Top 100';\n  }\n\n  results.push({\n    json: {\n      client_id,\n      client_name,\n      domain,\n      keyword,\n      country,\n      engine,\n      rank,\n      tier,\n      ranking_url: rankingUrl,\n      ranking_title: rankingTitle,\n      checked_at: new Date().toISOString()\n    }\n  });\n}\n\nreturn results;"
      },
