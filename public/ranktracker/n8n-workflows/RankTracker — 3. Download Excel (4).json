    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const client of $input.all()) {\n  const { id, client_name, domain, keywords, country, engine } = client.json;\n\n  let kwList = [];\n\n  // ✅ ALWAYS treat as string first\n  if (typeof keywords === 'string') {\n    kwList = keywords\n      .split(',')\n      .map(k => k.trim())\n      .filter(Boolean);\n  }\n  // fallback if array ever comes\n  else if (Array.isArray(keywords)) {\n    kwList = keywords;\n  }\n\n  for (const keyword of kwList) {\n    items.push({\n      json: {\n        client_id: id,\n        client_name,\n        domain,\n        keyword,\n        country,\n        engine\n      }\n    });\n  }\n}\n\nreturn items;"
      },
      "id": "a72fb9fb-5df6-4520-a5ff-2da9cc2f7f57",
      "name": "Split into one item per keyword",
      "type": "n8n-nodes-base.code",
